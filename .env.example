# Carbide2 environment template — copy to .env and edit.
# (quickstart.sh will generate a fresh .env for you if one doesn't exist.)

# Rails environment. Leave as development for local use.
RAILS_ENV=development

# DO NOT set DATABASE_URL for the dockerized stack — the Rails app reads
# host/user/password/db from the per-environment block in config/database.yml,
# which is wired to the postgres compose service. Setting DATABASE_URL here
# will override that and break the worker's connection.
# DATABASE_URL=postgres://carbide:carbide@postgres:5432/carbide2_development

# Worker JWT secret — any non-empty string for local dev; change for prod.
WORKER_JWT_SECRET=changeme
WORKER_TOKEN_EXPIRY_SECONDS=600

# Optional: OAuth providers (leave blank to disable social login)
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
