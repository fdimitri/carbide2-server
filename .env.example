# Database (SQLite path — leave as-is for local dev)
DATABASE_URL=sqlite3:storage/development.sqlite3

# Worker JWT secret — any non-empty string for local dev
WORKER_JWT_SECRET=changeme
WORKER_TOKEN_EXPIRY_SECONDS=600

# Optional: OAuth providers (leave blank to disable social login)
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
